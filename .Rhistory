# Xem bảng tỉ lệ dự đoán đúng từng nhóm
prop.table(table(test_set$GRADE_3LEVEL, pred_rf), 1)
features_short <- c("CUML_GPA", "ATTEND", "SCHOLARSHIP", "WORK")
formula_short <- as.formula(paste("GRADE_3LEVEL ~", paste(features_short, collapse = " + ")))
set.seed(123)
model_rf_short <- randomForest(formula_short,
data = train_set,
importance = TRUE,
ntree = 500)
pred_rf_short <- predict(model_rf_short, test_set)
cm_rf_short <- confusionMatrix(pred_rf_short, test_set$GRADE_3LEVEL)
cat("\n=== KẾT QUẢ MÔ HÌNH 4 BIẾN ===\n")
print(cm_rf_short$overall['Accuracy'])
print(cm_rf_short$table)
