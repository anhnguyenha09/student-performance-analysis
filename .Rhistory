data <- read.csv("data/processed/clean_data.csv")
model_data <- data %>%
mutate(
# --- Target: 3 nhóm ---
GRADE_GROUP = fct_collapse(GRADE,
Low = c("Fail", "DD", "DC"),
Mid = c("CC", "CB", "BB"),
High = c("BA", "AA")
),
# --- Convert ordinal rõ ràng ---
STUDY_HRS = as.numeric(STUDY_HRS),
ATTEND = as.numeric(ATTEND),
NOTES = as.numeric(NOTES),
LISTENS = as.numeric(LISTENS),
# --- Effort chuẩn (FIX BUG) ---
EFFORT_SCORE = STUDY_HRS + ATTEND + NOTES + LISTENS,
# --- Financial stress ---
FINANCIAL_STRESS = ifelse(
WORK == "Yes" & as.numeric(SALARY) <= 2,
"High", "Low"
),
# --- Social ---
SOCIAL_LIFE = ifelse(
PARTNER == "Yes" | ACTIVITY == "Yes",
"Active", "Isolated"
),
# --- Study behavior type (NEW) ---
STUDY_TYPE = case_when(
STUDY_HRS >= 3 & ATTEND >= 3 ~ "Hardcore",
STUDY_HRS >= 2 ~ "Balanced",
TRUE ~ "LowEffort"
)
) %>%
mutate(across(c(
AGE, GENDER, HS_TYPE, SCHOLARSHIP, TRANSPORT,
FINANCIAL_STRESS, SOCIAL_LIFE, STUDY_TYPE, GRADE_GROUP
), as.factor))
model_data$GRADE_GROUP <- factor(
model_data$GRADE_GROUP,
levels = c("Low", "Mid", "High"),
ordered = TRUE
)
set.seed(123)
trainIndex <- createDataPartition(model_data$GRADE_GROUP, p = 0.8, list = FALSE)
train_set <- model_data[trainIndex, ]
test_set  <- model_data[-trainIndex, ]
model_polr <- polr(
GRADE_GROUP ~ CUML_GPA * EFFORT_SCORE +
SCHOLARSHIP + GENDER + FINANCIAL_STRESS + TRANSPORT,
data = train_set,
Hess = TRUE
)
model_polr <- polr(
GRADE_GROUP ~ CUML_GPA * EFFORT_SCORE +
SCHOLARSHIP + GENDER + FINANCIAL_STRESS + TRANSPORT,
data = train_set,
Hess = TRUE
)
colSums(is.na(train_set))
