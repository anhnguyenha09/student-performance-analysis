GRADE_GROUP = fct_collapse(GRADE,
Low = c("Fail", "DD", "DC"),
Mid = c("CC", "CB", "BB"),
High = c("BA", "AA")),
# --- STUDY_HRS & HÀNH VI: Chuyển sang numeric để tính tổng nỗ lực ---
# Giả sử các mức 1, 2, 3... đại diện cho cường độ tăng dần
EFFORT_SCORE = as.numeric(as.factor(STUDY_HRS)) +
as.numeric(as.factor(ATTEND)) +
as.numeric(as.factor(NOTES)) +
as.numeric(as.factor(LISTENS)),
# --- BỐI CẢNH (Context): Tạo biến FINANCIAL_STRESS ---
# Nếu đi làm (WORK=1) và lương thấp (SALARY=1,2) hoặc không học bổng
FINANCIAL_STRESS = ifelse(WORK == "Yes" & (as.numeric(SALARY) <= 2), "High", "Low"),
# --- Biến Xã Hội ---
SOCIAL_LIFE = ifelse(PARTNER == "Yes" | ACTIVITY == "Yes", "Active", "Isolated")
) %>%
mutate(across(c(AGE, GENDER, HS_TYPE, SCHOLARSHIP, TRANSPORT, GRADE_GROUP,
FINANCIAL_STRESS, SOCIAL_LIFE), as.factor))
model_data$GRADE_GROUP <- factor(model_data$GRADE_GROUP,
levels = c("Low", "Mid", "High"),
ordered = TRUE)
set.seed(123)
trainIndex <- createDataPartition(model_data$GRADE_GROUP, p = 0.8, list = FALSE)
train_set <- model_data[trainIndex, ]
test_set  <- model_data[-trainIndex, ]
model_polr <- polr(GRADE_GROUP ~ CUML_GPA + SCHOLARSHIP + EFFORT_SCORE +
GENDER + FINANCIAL_STRESS + TRANSPORT,
data = train_set, Hess = TRUE)
pred_polr <- predict(model_polr, test_set)
pred_polr <- predict(model_polr, test_set)
conf_polr <- confusionMatrix(pred_polr, test_set$GRADE_GROUP)
print(conf_polr)
model_rf <- randomForest(GRADE_GROUP ~ CUML_GPA + SCHOLARSHIP + STUDY_HRS +
ATTEND + GENDER + SALARY + TRANSPORT + EFFORT_SCORE,
data = train_set,
importance = TRUE,
ntree = 500)
pred_rf <- predict(model_rf, test_set)
conf_rf <- confusionMatrix(pred_rf, test_set$GRADE_GROUP)
print(conf_rf)
importance_df <- as.data.frame(importance(model_rf))
importance_df$Variable <- rownames(importance_df)
p_imp <- ggplot(importance_df, aes(x = reorder(Variable, MeanDecreaseGini), y = MeanDecreaseGini)) +
geom_col(fill = "#2E7D32") +
coord_flip() +
labs(title = "Biến nào ảnh hưởng mạnh nhất đến GRADE?",
subtitle = "STUDY_HRS và EFFORT_SCORE đóng vai trò then chốt",
x = "Biến số", y = "Tầm quan trọng (Gini Index)") +
theme_minimal()
print(p_imp)
new_data <- data.frame(
EFFORT_SCORE = seq(min(model_data$EFFORT_SCORE), max(model_data$EFFORT_SCORE), length.out = 100),
CUML_GPA = factor(3), # Giả định GPA trung bình
SCHOLARSHIP = factor(3),
GENDER = factor("Male"),
FINANCIAL_STRESS = factor("Low"),
TRANSPORT = factor(1)
)
probs <- predict(model_polr, new_data, type = "probs")
probs <- predict(model_polr, new_data, type = "probs")
new_data <- cbind(new_data, probs) %>%
pivot_longer(cols = c("Low", "Mid", "High"), names_to = "Level", values_to = "Prob")
